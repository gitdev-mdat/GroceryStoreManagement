# Supabase config — SAO CHÉP file này thành `.env.local` rồi điền giá trị
# (file .env.local KHÔNG được commit lên git)

# URL project Supabase (lấy từ Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon public key (lấy từ Dashboard → Settings → API → Project API keys → anon/public)
# Đây là key PUBLIC, an toàn để lộ trong code (đã được RLS bảo vệ).
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
